<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F0F0F"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <item android:top="16dp" android:bottom="16dp" android:left="16dp" android:right="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#F0EDE8"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- Center dot (die face 1) -->
    <item android:top="44dp" android:bottom="44dp" android:left="44dp" android:right="44dp">
        <shape android:shape="oval">
            <solid android:color="#1A1A1A"/>
        </shape>
    </item>
</layer-list>
